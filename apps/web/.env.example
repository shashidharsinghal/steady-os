# Supabase
NEXT_PUBLIC_SUPABASE_URL=           # Your Supabase project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # Supabase anon/public key
SUPABASE_SERVICE_ROLE_KEY=          # Supabase service role key (server only)

# Security
PHONE_HASH_SALT=                    # Random 32+ char string for hashing customer phones
CRON_SECRET=                        # Shared secret for Vercel cron route authorization

# Petpooja
PETPOOJA_MAPPING_CODE=              # ADSR mapping code from Petpooja (e.g. 12vmeiw05y)

# Gmail OAuth (for auto-ingest)
GOOGLE_CLIENT_ID=                   # Google Cloud Console OAuth client ID
GOOGLE_CLIENT_SECRET=               # Google Cloud Console OAuth client secret
GMAIL_OAUTH_REDIRECT_URI=           # Must match Vercel production URL + /api/gmail/callback

# App
NEXT_PUBLIC_APP_URL=                # Production URL e.g. https://stride.steadystrides.in

# Optional alerts
WHATSAPP_ALERT_WEBHOOK_URL=         # Review-needed alert webhook destination
